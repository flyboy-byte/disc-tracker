# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# iOS is out of scope for now — not generated, nothing to ignore/commit yet.
/ios

# android/ IS committed (see CLAUDE.md / PORT_PLAN.md Phase 1) — only credentials inside it
# are gitignored, matching DragTree's local.properties null-guard pattern.
android/local.properties
android/app/*.keystore
android/app/*.jks
